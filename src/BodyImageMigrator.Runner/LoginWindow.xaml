<Window x:Class="BodyImageMigrator.Runner.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ログイン - BodyImageMigrator" Height="180" Width="380"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize">
    <Grid Margin="24,24,24,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,20">
            <TextBlock Text="ユーザー名" VerticalAlignment="Center" Width="80" Margin="0,0,8,0"/>
            <TextBox x:Name="TxtUsername" Width="220" Padding="6,4" VerticalContentAlignment="Center"/>
        </StackPanel>
        <Button Grid.Row="1" x:Name="BtnLogin" Content="ログイン" Width="120" Height="32" Click="BtnLogin_Click"/>
    </Grid>
</Window>
