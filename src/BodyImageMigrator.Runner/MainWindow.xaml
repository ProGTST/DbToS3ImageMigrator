<Window x:Class="BodyImageMigrator.Runner.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="BodyImageMigrator - 身体図画像 DB→S3 移行ツール" Height="720" Width="780"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 実行パラメータ -->
        <GroupBox Grid.Row="0" Header="実行パラメータ" Padding="12" Margin="0,0,0,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" MinWidth="140"/>
                    <ColumnDefinition Width="450" MinWidth="350"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,12">
                    <CheckBox x:Name="ChkDryRun" Content="ドライラン（アップロードしない）" VerticalAlignment="Center" Margin="0,0,20,0"/>
                    <TextBlock Text="並列数" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <ComboBox x:Name="CmbParallel" Width="56" HorizontalAlignment="Left" Margin="0,0,20,0"/>
                    <TextBlock Text="最大件数（未入力=無制限）" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="TxtLimit" Width="80" HorizontalAlignment="Left" PreviewTextInput="TxtLimit_PreviewTextInput" MaxLength="12"/>
                </StackPanel>
                <TextBlock Grid.Row="1" Grid.Column="0" Text="施設コード" VerticalAlignment="Center" Margin="0,0,12,8"/>
                <TextBox x:Name="TxtIstcd" Grid.Row="1" Grid.Column="1" Margin="0,0,0,8" Width="368" MinWidth="336" HorizontalAlignment="Left"/>
                <TextBlock Grid.Row="2" Grid.Column="0" Text="記録日" VerticalAlignment="Center" Margin="0,0,12,8"/>
                <StackPanel Grid.Row="2" Grid.Column="1" Orientation="Horizontal" Margin="0,0,0,8">
                    <DatePicker x:Name="DpFrom" Width="180" MinWidth="160" HorizontalAlignment="Left" Margin="0,0,8,0"/>
                    <TextBlock Text="～" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="DpTo" Width="180" MinWidth="160" HorizontalAlignment="Left"/>
                </StackPanel>
                <TextBlock Grid.Row="3" Grid.Column="0" Text="ログ出力先" VerticalAlignment="Center" Margin="0,0,12,8"/>
                <Grid Grid.Row="3" Grid.Column="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" MinWidth="200"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="TxtOutputPath" Grid.Column="0" VerticalAlignment="Center" Margin="0,0,8,0"
                             ToolTip="未入力時は publish\BodyImageMigration を使用"/>
                    <Button x:Name="BtnBrowse" Grid.Column="1" Content="参照..." Width="70" Click="BtnBrowse_Click"/>
                </Grid>
            </Grid>
        </GroupBox>

        <!-- オプション -->
        <GroupBox Grid.Row="1" Header="オプション" Padding="12" Margin="0,0,0,12">
            <StackPanel Orientation="Horizontal">
                <CheckBox x:Name="ChkOverwrite" Content="上書き（S3に同一キーが既にある場合も上書きする）" IsChecked="True" Margin="0,0,20,0"/>
                <CheckBox x:Name="ChkExcludeDeleted" Content="削除済み除外" Margin="0,0,0,0"/>
            </StackPanel>
        </GroupBox>

        <!-- 出力エリア -->
        <GroupBox Grid.Row="2" Header="実行ログ" Padding="8" Margin="0,0,0,12">
            <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Auto">
                <TextBox x:Name="TxtLog" IsReadOnly="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Disabled" HorizontalScrollBarVisibility="Disabled"
                         FontFamily="Consolas" FontSize="12" Padding="8"
                         Background="#1e1e1e" Foreground="#d4d4d4" BorderThickness="0"/>
            </ScrollViewer>
        </GroupBox>

        <!-- フッター -->
        <Grid Grid.Row="3">
            <Button x:Name="BtnAccessKey" Content="アクセスキー" Width="100" Height="36" HorizontalAlignment="Left" Click="BtnAccessKey_Click"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="BtnRun" Content="実行" Width="100" Height="36" Margin="0,0,8,0" Click="BtnRun_Click"/>
                <Button x:Name="BtnStop" Content="中止" Width="100" Height="36" IsEnabled="False" Click="BtnStop_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
